{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": { "api/*.js": { "maxDuration": 60 } },
  "crons": [{ "path": "/api/transactions", "schedule": "0 14 * * 1" }],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}